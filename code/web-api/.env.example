# ── Server ───────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Database (PostgreSQL — non-default port 5431) ────────────
DB_HOST=localhost
DB_PORT=5431
DB_USER=declay_admin
DB_PASSWORD=your_db_password
DB_NAME=declay_store

# ── Redis (non-default port 6378) ────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6378
# REDIS_PASSWORD=your_redis_password   # optional, only if Redis requires auth
REDIS_DB=0

# ── JWT (customer) ───────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_EXPIRED_IN=15m
JWT_REFRESH_EXPIRED_IN=7d

# ── JWT (admin — separate table, separate secret) ────────────
JWT_ADMIN_SECRET=change_me_admin_secret
JWT_ADMIN_EXPIRED_IN=8h

# ── Password hashing ─────────────────────────────────────────
AUTH_SALT_ROUNDS=10

# ── Google OAuth ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback
FRONTEND_URL=http://localhost:3000

# ── Session ──────────────────────────────────────────────────
SESSION_SECRET=change_me_session_secret

# ── Stripe ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Local webhook testing: stripe listen --forward-to localhost:3000/api/webhooks/stripe

# ── Email (SMTP) ──────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=Declay Store <noreply@declay.store>
