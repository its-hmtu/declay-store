PORT=3000
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/declay_store
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

JWT_ACCESS_SECRET=replace-with-long-random-string
JWT_REFRESH_SECRET=replace-with-long-random-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

AUTH_DEMO_EMAIL=admin@declay.local
AUTH_DEMO_PASSWORD=changeme
AUTH_DEMO_ROLE=admin
AUTH_DEMO_USER_ID=demo-user
# Optional: use hashed password instead of plain AUTH_DEMO_PASSWORD
# AUTH_DEMO_PASSWORD_HASH=$2a$10$example
